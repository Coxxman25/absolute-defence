    {
      "name": "a1b2c3d4-1111-2222-3333-444455556666",
      "valid": true,
      "displayName": "AI Safeguarding Analysis",
      "type": "PIECE",
      "settings": {
        "pieceName": "@taskade/automade-internalpiece-openai",
        "pieceVersion": "1.0.0",
        "actionName": "ai.ask",
        "input": {
          "input": "Mood: {{ trigger[\"body\"][\"mood\"] }} | Entry: {{ trigger[\"body\"][\"transcription\"] }}",
          "prompt": "You are a safeguarding and wellbeing AI analyst. Analyse the following voice journal entry submitted anonymously by a person at an organisation or venue. Return ONLY a valid JSON object with exactly two fields:\n1. \"flag\" — one of: \"none\" (positive/neutral, no concern), \"monitor\" (mild negativity, worth watching over time), \"concern\" (clear distress, threat, or safeguarding issue mentioned), \"urgent\" (immediate danger, self-harm, abuse, or violence mentioned)\n2. \"summary\" — a brief 1-2 sentence summary for the Safety Lead describing what the person expressed and any safeguarding relevance.\n\nPerson mood: {{ trigger[\"body\"][\"mood\"] }}\nPerson said: {{ trigger[\"body\"][\"transcription\"] }}\n\nRespond ONLY with the raw JSON object. No markdown, no code fences, no extra text."
        }
      }
    },
    {
