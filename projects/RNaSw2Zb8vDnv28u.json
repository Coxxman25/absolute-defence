              {
                "type": "text",
                "id": "d3e4f567-890a-bcde-f012-3456789abcde",
                "text": {
                  "ops": [
                    {
                      "insert": "9 specialised agents, each eliminating a specific industry bottleneck. Each agent has: defined domain, clear inputs/outputs, inter-agent communication protocols, and autonomous decision boundaries.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
