            "children": [
              {
                "type": "text",
                "id": "f5678901-bcde-f012-3456-789abcdef012",
                "text": {
                  "ops": [
                    {
                      "insert": "1. SENTINEL (Orchestrator) — Central coordinator. Routes incidents to appropriate agents. Manages handoffs. Monitors agent health. Escalates when human decision required.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
                  "children": null
                },
                "collapsed": false,
                "completed": false,
                "children": []
              },
              {
                "type": "text",
                "id": "06789012-cdef-0123-4567-89abcdef0123",
                "text": {
                  "ops": [
                    {
                      "insert": "2. ARIA (Threat Intelligence) — Analyses incoming reports. Sentiment analysis on voice. Risk scoring. Pattern recognition. Predictive heatmapping. Feeds intelligence to all other agents.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
                  "children": null
                },
                "collapsed": false,
                "completed": false,
                "children": []
              },
              {
                "type": "text",
                "id": "17890123-def0-1234-5678-9abcdef01234",
                "text": {
                  "ops": [
                    {
                      "insert": "3. GUARDIAN (Triage & Response) — Receives incident from ARIA. Classifies severity. Triggers Acknowledgement Chain. Deploys real-time situational guidance to person at risk. Manages response SLA countdown.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
                  "children": null
                },
                "collapsed": false,
                "completed": false,
                "children": []
              },
              {
                "type": "text",
                "id": "28901234-ef01-2345-6789-abcdef012345",
                "text": {
                  "ops": [
                    {
                      "insert": "4. WITNESS (Evidence & Documentation) — Constructs the Case Vault entry in real-time. Chains evidence. Timestamps every acknowledgement. Produces courtroom-ready packs. Serves GDPR subject access requests.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
                  "children": null
                },
                "collapsed": false,
                "completed": false,
                "children": []
              },
              {
                "type": "text",
                "id": "39012345-f012-3456-789a-bcdef0123456",
                "text": {
                  "ops": [
                    {
                      "insert": "5. COMPASS (Compliance) — Monitors Martyn's Law obligations. Tracks RIDDOR 10-day windows. Auto-classifies incidents against regulatory frameworks. Generates compliance reports. Alerts before breaches.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
                  "children": null
                },
                "collapsed": false,
                "completed": false,
                "children": []
              },
              {
                "type": "text",
                "id": "40123456-0123-4567-89ab-cdef01234567",
                "text": {
                  "ops": [
                    {
                      "insert": "6. ORACLE (Predictive Analytics) — Learns from historical incidents across all sites. Recency-weighted heatmaps. Seasonal/temporal pattern detection. Proactive risk advisories. Feeds GUARDIAN with pre-positioned response plans.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
                  "children": null
