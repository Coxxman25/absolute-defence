                  "ops": [
                    {
                      "insert": "9. SHIELD (Insurance & Risk Transfer) — Generates insurance evidence packs on-demand. Calculates risk scores per site. Produces premium reduction documentation. Interfaces with insurers' risk assessment frameworks.",
                      "attributes": {}
