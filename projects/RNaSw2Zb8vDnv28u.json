                "text": {
                  "ops": [
                    {
                      "insert": "8. FORGE (Training & Readiness) — Analyses incident patterns to identify training gaps. Generates scenario-based training recommendations. Tracks certification/competency. Suggests deployment optimisations based on personnel capability.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
