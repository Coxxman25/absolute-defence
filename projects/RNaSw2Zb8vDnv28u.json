                "text": {
                  "ops": [
                    {
                      "insert": "Pattern: Supervisor-Handoff Hybrid. A central Orchestrator Agent (SENTINEL) routes to specialised agents. Agents can also hand off directly to each other when workflow demands it. Shared memory bus for state.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
