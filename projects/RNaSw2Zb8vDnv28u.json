                "children": []
              },
              {
                "type": "text",
                "id": "51234567-1234-5678-9abc-def012345678",
                "text": {
                  "ops": [
                    {
                      "insert": "7. BRIDGE (Stakeholder Communication) — Manages multi-channel comms. Notifies Safety Leads, escalation contacts, emergency services. Generates client reports. Handles victim follow-up scheduling. Multi-language support.",
                      "attributes": {}
                    },
                    {
                      "insert": "\n",
                      "attributes": {
                        "paragraph": true
                      }
                    }
                  ]
                },
                "format": {
                  "node": "bullet",
                  "children": null
                },
