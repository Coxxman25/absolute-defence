          {
            "type": "text",
            "id": "01234567-89ab-cdef-0123-456789abcdef",
            "text": {
              "ops": [
                {
                  "insert": "TrackTik Core Gaps — What We Have That They Don't",
                  "attributes": {}
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
            "format": {
              "node": "h1",
